{
  "manifest_version": 3,
  "name": "Saccade New Tab",
  "version": "0.2.0",
  "description": "Saccade new tab identity and per-tab Agent control.",
  "key": "",
  "permissions": ["nativeMessaging"],
  "background": {
    "service_worker": "agent-action.js"
  },
  "action": {
    "default_title": "Agent Off - current tab",
    "default_icon": {
      "16": "Saccade.png",
      "32": "Saccade.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
