+void SimpleApp::OnBeforeCommandLineProcessing(
+    const CefString& process_type,
+    CefRefPtr<CefCommandLine> command_line) {
+#if defined(OS_MAC)
+  if (!process_type.empty()) {
+    return;
+  }
+
+  char executable[PATH_MAX] = {};
+  uint32_t executable_size = sizeof(executable);
+  if (_NSGetExecutablePath(executable, &executable_size) != 0) {
+    return;
+  }
+  std::string extension_path(executable);
+  const size_t slash = extension_path.rfind('/');
+  if (slash == std::string::npos) {
+    return;
+  }
+  extension_path.resize(slash);
+  extension_path.append("/../Resources/extensions/saccade-new-tab");
+
+  char resolved[PATH_MAX] = {};
+  if (!realpath(extension_path.c_str(), resolved)) {
+    return;
+  }
+  struct stat status {};
+  if (stat(resolved, &status) != 0 || !S_ISDIR(status.st_mode)) {
+    return;
+  }
+
+  std::string extensions(resolved);
+  const CefString current = command_line->GetSwitchValue("load-extension");
+  if (!current.empty()) {
+    extensions.append(",");
+    extensions.append(current.ToString());
+  }
+  command_line->AppendSwitchWithValue("load-extension", extensions);
+#endif
+}
+
 void SimpleApp::OnContextInitialized() {
   CEF_REQUIRE_UI_THREAD();

+#if defined(OS_MAC)
+  // Run before the first browser window is created so the action occupies the
+  // Chromium toolbar between the address bar and the profile control.
+  PinSaccadeAgentAction();
+#endif
+
   CefRefPtr<CefCommandLine> command_line =
       CefCommandLine::GetGlobalCommandLine();
