+#if defined(OS_MAC)
+constexpr char kSaccadeAgentExtensionId[] =
+    "kfmcgnphhefgadoabheodbhdndhfmonl";
+
+void PinSaccadeAgentAction() {
+  CefRefPtr<CefPreferenceManager> preferences =
+      CefPreferenceManager::GetGlobalPreferenceManager();
+  constexpr char kPinnedExtensions[] = "extensions.pinned_extensions";
+  if (!preferences || !preferences->CanSetPreference(kPinnedExtensions)) {
+    return;
+  }
+
+  CefRefPtr<CefListValue> pinned = CefListValue::Create();
+  pinned->SetString(0, kSaccadeAgentExtensionId);
+  size_t next = 1;
+  CefRefPtr<CefValue> current = preferences->GetPreference(kPinnedExtensions);
+  if (current && current->GetType() == VTYPE_LIST) {
+    CefRefPtr<CefListValue> current_list = current->GetList();
+    for (size_t index = 0; index < current_list->GetSize(); ++index) {
+      if (current_list->GetType(index) != VTYPE_STRING) {
+        continue;
+      }
+      const CefString extension_id = current_list->GetString(index);
+      if (extension_id != kSaccadeAgentExtensionId) {
+        pinned->SetString(next++, extension_id);
+      }
+    }
+  }
+
+  CefRefPtr<CefValue> value = CefValue::Create();
+  value->SetList(pinned);
+  CefString error;
+  preferences->SetPreference(kPinnedExtensions, value, error);
+}
+#endif
