+  void UpdateAgentButton() {
+    if (!agent_button_) {
+      return;
+    }
+    const auto state = SaccadeAdapter::GetInstance()->GetAgentUiState();
+    if (state == SaccadeAdapter::AgentUiState::kOn) {
+      agent_button_->SetText("Agent On");
+      agent_button_->SetEnabledTextColors(CefColorSetARGB(255, 20, 125, 70));
+      agent_button_->SetTooltipText(
+          "Agent can read and act in the visible tab; click to pause");
+    } else if (state == SaccadeAdapter::AgentUiState::kPaused) {
+      agent_button_->SetText("Agent Paused");
+      agent_button_->SetEnabledTextColors(CefColorSetARGB(255, 160, 95, 0));
+      agent_button_->SetTooltipText(
+          "Agent access is paused; click to resume");
+    } else if (state == SaccadeAdapter::AgentUiState::kUnavailable) {
+      agent_button_->SetText("Agent unavailable");
+      agent_button_->SetEnabledTextColors(CefColorSetARGB(255, 95, 99, 104));
+      agent_button_->SetTooltipText(
+          "Launch with the Saccade agent session to enable this control");
+    } else {
+      agent_button_->SetText("Agent Off");
+      agent_button_->SetEnabledTextColors(CefColorSetARGB(255, 75, 80, 88));
