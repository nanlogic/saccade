 SimpleApp::SimpleApp() = default;

+void SimpleApp::OnBeforeCommandLineProcessing(
+    const CefString& process_type,
+    CefRefPtr<CefCommandLine> command_line) {
+#if defined(OS_WIN)
+  if (!process_type.empty()) {
+    return;
+  }
+
+  wchar_t executable[MAX_PATH] = {};
+  const DWORD length =
+      ::GetModuleFileNameW(nullptr, executable, MAX_PATH);
+  if (length == 0 || length >= MAX_PATH) {
+    return;
+  }
+
+  std::wstring extension_path(executable, length);
+  const size_t slash = extension_path.find_last_of(L"\\/");
+  if (slash == std::wstring::npos) {
+    return;
+  }
+  extension_path.resize(slash);
+  extension_path.append(L"\\extensions\\saccade-new-tab");
+
+  const DWORD attributes =
+      ::GetFileAttributesW(extension_path.c_str());
+  if (attributes == INVALID_FILE_ATTRIBUTES ||
+      !(attributes & FILE_ATTRIBUTE_DIRECTORY)) {
+    return;
+  }
+
+  CefString current = command_line->GetSwitchValue("load-extension");
+  if (!current.empty()) {
+    extension_path.append(L",");
+    extension_path.append(current.ToWString());
+  }
+  command_line->AppendSwitchWithValue("load-extension", extension_path);
+#endif
+}
