+- (void)connectSaccadeToCodex:(id)sender {
+  NSString* executable = [[NSBundle mainBundle] executablePath];
+  NSString* helper = [[executable stringByDeletingLastPathComponent]
+      stringByAppendingPathComponent:@"saccade-connect-codex"];
+  NSTask* task = [[NSTask alloc] init];
+  [task setLaunchPath:helper];
+  [task setArguments:@[ @"--repair" ]];
+  BOOL launched = NO;
+  @try {
+    [task launch];
+    launched = YES;
+    [task waitUntilExit];
+  } @catch (NSException* exception) {
+    launched = NO;
+  }
+
+  NSAlert* alert = [[NSAlert alloc] init];
+  [alert setAlertStyle:launched && [task terminationStatus] == 0
+                           ? NSAlertStyleInformational
+                           : NSAlertStyleWarning];
+  if (launched && [task terminationStatus] == 0) {
+    [alert setMessageText:@"Saccade is connected to Codex"];
+    [alert setInformativeText:
+               @"Restart Codex or open a new task once. Future tasks will "
+                "discover the signed Saccade MCP automatically."];
+  } else {
+    [alert setMessageText:@"Codex connection needs attention"];
+    [alert setInformativeText:
+               @"Install Codex for this macOS user, then choose this command "
+                "again. Saccade did not change another MCP configuration."];
+  }
+  [alert runModal];
+}
